# Environment Variables for Midwest Healthcare Staffing Agency
# Copy this file to .env and fill in your actual values

# Form Backend Service
# Options: formspree, netlify, backend_api
FORM_SERVICE=formspree
FORMSPREE_FORM_ID=your_formspree_id_here

# Email Configuration
CONTACT_EMAIL=support@midwesthealthcarestaffing.com
ADMIN_EMAIL=admin@midwesthealthcarestaffing.com

# Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# API Endpoints (if using custom backend)
API_BASE_URL=https://api.midwesthealthcarestaffing.com
API_TIMEOUT=5000

# Feature Flags
ENABLE_ANIMATIONS=true
ENABLE_ANALYTICS=true
DEBUG_MODE=false

# Site Configuration
SITE_URL=https://midwesthealthcarestaffing.com
SITE_NAME=Midwest Healthcare Staffing Agency
